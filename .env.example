# Groq API Key (FREE - recommended for deployment)
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key for summary generation (optional, paid)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: News API key for additional sources
NEWS_API_KEY=your_newsapi_key_here

# Output directory for generated digests
OUTPUT_DIR=output

# Schedule time for daily digest (24-hour format)
DIGEST_TIME=08:00
